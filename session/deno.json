    "check": "deno fmt --check && deno check ./src && deno lint ./src && deno run -A ../tools/check-docs.ts && deno test -A ./tests"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./memory-store": "./src/stores/memory.ts",
    "./kv-store": "./src/stores/kv.ts",
