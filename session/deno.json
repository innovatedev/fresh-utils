    "./kvdex-store": "./src/stores/kvdex.ts",
    "./define": "./src/define.ts"
  },
  "imports": {
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "@std/http": "jsr:@std/http@^1.0.22",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.11"
  },
  "publish": {
    "exclude": [
      "tests"
    ]
